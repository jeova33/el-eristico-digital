# Copia a .env.local (local) o Variables en Railway. NUNCA subas claves a git.

# Proveedor por defecto: auto | xai | gemini | nvidia
# (auto = primer key disponible: xai → gemini → nvidia)
LLM_PROVIDER=auto

# —— Grok / xAI — https://console.x.ai
XAI_API_KEY=
# XAI_MODEL=grok-4.5

# —— Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Recomendado (estable):
# GEMINI_MODEL=gemini-2.0-flash

# —— NVIDIA NIM — https://build.nvidia.com (API key)
NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
